#include "shared/erp-serverinfo.hxx"
#include "shared/util/SharedRequirements.hxx"

std::string_view ErpServerInfo::BuildVersion()
{
    return "@ERP_BUILD_VERSION@";
}

std::string_view ErpServerInfo::BuildType()
{
    return "@CMAKE_BUILD_TYPE@";
}

std::string_view ErpServerInfo::ReleaseVersion()
{
    return "@ERP_RELEASE_VERSION@";
}

std::string_view ErpServerInfo::ReleaseDate()
{
    return "@ERP_RELEASE_DATE@";
}

std::string_view ErpServerInfo::GematikClientId()
{
    A_22470_06.start("Client-ID for x-useragent header provided by Gematik:");
    return "ERP-FD";
}
