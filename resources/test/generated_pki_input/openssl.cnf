professionOIDs=SEQUENCE:arzt_oid_sect
professionItems.1 = PRINTABLESTRING:"1-Arzt-1"

[arzt_professionItems_sect]
professionItem.0 = UTF8String:"Ärztin/Arzt"

[arzt_oid_sect]
one=OID:oid_arzt

####################################################################
[apotheker]
# PKIX recommendations harmless if included in all certificates.
subjectKeyIdentifier   = hash
keyUsage               = critical,nonRepudiation
basicConstraints       = critical,CA:FALSE
certificatePolicies    = @qes_policy_hba_cp,oid_hba_qes,qcp-natural-qscd
authorityInfoAccess    = OCSP;URI:http://ocsp.test.ibm.de/
authorityKeyIdentifier = keyid,issuer
x509ExtAdmission       = ASN1:SEQUENCE:apotheker_profession_oids
qcStatements           = ASN1:SEQUENCE:qes_qcStatement

[apotheker_profession_oids]
