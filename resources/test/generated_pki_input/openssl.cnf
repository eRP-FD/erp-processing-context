contentsOfAdmissions = SEQWRAP, SEQUENCE:apotheker_admission0_sect

[apotheker_admission0_sect]
professionInfos = SEQUENCE:apotheker_professionInfos_sect

[apotheker_professionInfos_sect]
professionInfo.0 = SEQUENCE:apotheker_professionInfo0_sect

[apotheker_professionInfo0_sect]
professionItems = SEQUENCE:apotheker_professionItems_sect
professionOIDs=SEQUENCE:apotheker_oid_sect
professionItems.1 = PRINTABLESTRING:"1-Apotheker-1"

[apotheker_professionItems_sect]
professionItem.0 = UTF8String:"Apothekerin/Apotheker"

[apotheker_oid_sect]
one=OID:oid_apotheker

