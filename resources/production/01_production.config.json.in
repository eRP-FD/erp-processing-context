{
  "erp": {
    "publicEPrescriptionServiceUrl": "https://gematik.erppre.de:443",
    "server": {
      "thread-count": "10",
      "token": {
        "ulimitCalls": "200",
        "ulimitTimespanMS": "1000"
      },
      "proxy": {
        "certificate": ""
      }
    },
    "ocsp": {
      "gracePeriodCFdSigErp": "86400",
      "gracePeriodSmcBOsig": "43200",
      "gracePeriodNonQes": "3600",
      "gracePeriodQes": "43200"
    },
    "tsl": {
      "tiOcspProxyUrl": "",
      "sslRootCaPath": "",
      "initialDownloadUrl": "http://download-ref.tsl.telematik-test:80/ECC/ECC-RSA_TSL-ref.xml",
      "initialCaDerPath": "/erp/config/tsl/tsl-ca.der",
      "refreshInterval": "86400",
      "downloadCiphers": "",
      "initialCaDerPathStart": "",
      "initialCaDerPathNew": ""
    },
    "service": {
      "task": {
        "activate": {
          "entlassRezeptValidityInWorkDays": "3",
          "holidays": [
            "01-01",
            "Karfreitag",
            "Ostermontag",
            "05-01",
            "Himmelfahrt",
            "Pfingstmontag",
            "10-03",
            "12-25",
            "12-26"
          ],
          "easterCsv": "@ERP_RUNTIME_RESOURCE_DIR@/easter.csv",
          "kbvValidationOnUnknownExtension": "reject",
          "kbvValidationNonLiteralAuthorRef": "allow",
          "anrChecksumValidationMode": "warning"
        },
        "close": {
          "prescriptionDigestMetaVersionId": "1"
        },
        "get": {
          "enforceHcvCheck": "false",
          "rateLimit": "100"
        }
      },
      "communication": {
        "maxMessageCount": "10"
      },
      "subscription": {
        "signingKey": "-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQgBwZpm6omGaV11Lev\nmIQtqZCJEGvvXz2ocHzPeNQBmQyhRANCAARBPhwSXbt0WV0HXmEwCmma6ddKPzxx\nmqS1p2Bktj9v17J9yv8lhvjiAdhQ84R/ZGDHfAUw4FA9Mue7GKnnXK5B\n-----END PRIVATE KEY-----\n"
      },
      "pcr-set": "0,3,4"
    },
    "postgres": {
      "host": "localhost",
      "port": "5432",
      "user": "postgres",
      "password": "Postgres Admin Password",
      "database": "erp_processing_context",
      "useSsl": "true",
      "certificatePath": "",
      "connectTimeoutSeconds": "2",
      "tcpUserTimeoutMs": "1000",
      "keepalivesIdleSec": "75",
      "keepalivesIntervalSec": "75",
      "keepalivesCount": "9",
      "targetSessionAttrs": "read-write",
      "enableScramAuthentication": "false",
      "connectionMaxAgeMinutes": "120"
    },
    "json-meta-schema": "@ERP_SCHEMA_DIR@shared/json/draft-4-meta-schema.json",
    "json-schema": [
      "@ERP_SCHEMA_DIR@hl7.fhir.r4.core/4.0.1/json/fhir.json",
      "@ERP_SCHEMA_DIR@shared/json/CommunicationDispReqPayload.json",
      "@ERP_SCHEMA_DIR@shared/json/CommunicationReplyPayload.json"
    ],
    "xml-schema": [
      "@ERP_SCHEMA_DIR@hl7.fhir.r4.core/4.0.1/xml/fhir.xsd",
      "@ERP_SCHEMA_DIR@tsl/BNA_tsl.xsd",
      "@ERP_SCHEMA_DIR@tsl/Gematik_tsl.xsd",
      "@ERP_SCHEMA_DIR@vsdm/Pruefungsnachweis.xsd"
    ],
    "fhir": {
      "validation": {
        "urnUuidCheckFrom": "2025-10-01",
        "fullUrlAndBundleReferenceCheckFrom": "2026-04-01",
        "rejectUnslicedExtensionsFrom": "2026-04-01",
        "levels": {
          "unreferenced-bundled-resource": "error",
          "unreferenced-contained-resource": "error",
          "mandatory-resolvable-reference-failure": "error",
          "missing-or-extra-meta-profile": "error"
        }
      },
      "reference-time-offset-days": "0",
      "version-mapping": [
        {
          "urlRegex": "https://gematik\\.de/fhir/erp-eu/StructureDefinition/GEM_ERPEU_PR_.*",
          "versionRegex": "1\\.1",
          "realVersion": "1.1.1",
          "renderVersion": "1.1"
        },
        {
          "urlRegex": "https://gematik\\.de/fhir/erp/StructureDefinition/GEM_ERP_PR_.*",
          "versionRegex": "1\\.5",
          "realVersion": "1.5.2",
          "renderVersion": "1.5"
        },
        {
          "urlRegex": "https://gematik\\.de/fhir/erpchrg/StructureDefinition/GEM_ERPCHRG_PR_.*",
          "versionRegex": "1\\.1",
          "realVersion": "1.1.0",
          "renderVersion": "1.1"
        },
        {
          "urlRegex": "https://fhir.kbv.de/StructureDefinition/KBV_PR_FOR_.*",
          "versionRegex": "1\\.2",
          "realVersion": "1.2.1",
          "renderVersion": "1.2"
        },
        {
          "urlRegex": "https://fhir.kbv.de/StructureDefinition/KBV_PR_ERP_.*",
          "versionRegex": "1\\.3",
          "realVersion": "1.3.3",
          "renderVersion": "1.3"
        },
        {
          "urlRegex": "https://fhir.kbv.de/StructureDefinition/KBV_PR_EVDGA_.*",
          "versionRegex": "1\\.2",
          "realVersion": "1.2.2",
          "renderVersion": "1.2"
        },
        {
          "urlRegex": "http://fhir\\.abda\\.de/eRezeptAbgabedaten/StructureDefinition/DAV-PKV-PR-ERP-.*",
          "versionRegex": "1\\.4",
          "realVersion": "1.4.0",
          "renderVersion": "1.4"
        }
      ],
      "schluesseltabellen": [
        {
          "id": "2025-Q2",
          "groups": [
            "KBV-Schluesseltabellen-Q2/25"
          ]
        }
      ],
      "resource-views": [
        {
          "id": "2024-10-01",
          "valid-until": "2025-04-15",
          "groups": [
            "kbv.ita.erp-1.1.0",
            "de.gematik.erezept-workflow.r4-1.2",
            "de.gematik.erezept-patientenrechnung.r4-1.0-FdV",
            "de.gematik.erezept-patientenrechnung.r4-1.0-non-FdV"
          ]
        },
        {
          "id": "2024-11-01",
          "valid-from": "2024-11-01",
          "valid-until": "2025-04-15",
          "groups": [
            "kbv.ita.erp-1.1.0",
            "de.gematik.erezept-workflow.r4-1.3",
            "de.gematik.erezept-patientenrechnung.r4-1.0-FdV",
            "de.gematik.erezept-patientenrechnung.r4-1.0-non-FdV"
          ]
        },
        {
          "id": "KBV_2023-07-01",
          "valid-from": "2025-01-01",
          "valid-until": "2026-03-31",
          "groups": [
            "kbv.ita.erp-1.1.0"
          ]
        },
