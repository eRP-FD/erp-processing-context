{
  "erp": {
    "publicEPrescriptionServiceUrl": "https://gematik.erppre.de:443",
    "server": {
      "thread-count": "10",
      "token": {
        "ulimitCalls": "200",
        "ulimitTimespanMS": "1000"
      },
      "proxy": {
        "certificate": ""
      }
    },
    "ocsp": {
      "gracePeriodCFdSigErp": "86400",
      "gracePeriodSmcBOsig": "43200",
      "gracePeriodNonQes": "3600",
      "gracePeriodQes": "43200"
    },
    "tsl": {
      "tiOcspProxyUrl": "",
      "sslRootCaPath": "",
      "initialDownloadUrl": "http://download-ref.tsl.telematik-test:80/ECC/ECC-RSA_TSL-ref.xml",
      "initialCaDerPath": "/erp/config/tsl/tsl-ca.der",
      "refreshInterval": "86400",
      "downloadCiphers": "",
      "initialCaDerPathStart": "",
      "initialCaDerPathNew": ""
    },
    "service": {
      "task": {
        "activate": {
          "entlassRezeptValidityInWorkDays": "3",
          "holidays": [
            "01-01",
            "Karfreitag",
            "Ostermontag",
            "05-01",
            "Himmelfahrt",
            "Pfingstmontag",
            "10-03",
            "12-25",
            "12-26"
          ],
          "easterCsv": "@ERP_RUNTIME_RESOURCE_DIR@/easter.csv",
          "kbvValidationOnUnknownExtension": "reject",
          "kbvValidationNonLiteralAuthorRef": "allow",
          "anrChecksumValidationMode": "warning"
        },
        "close": {
          "prescriptionDigestMetaVersionId": "1"
        },
        "get": {
          "enforceHcvCheck": "false",
          "rateLimit": "100"
        }
      },
      "communication": {
        "maxMessageCount": "10",
        "payloadV1ValidUntil": "2099-12-31",
        "payloadV3ValidFrom": "2026-10-01"
      },
      "subscription": {
        "signingKey": ""
      },
      "pcr-set": "0,3,4"
    },
    "postgres": {
      "main": {
        "host": "localhost",
        "port": "5432",
        "user": "postgres",
        "password": "Postgres Admin Password",
        "database": "erp_processing_context",
        "useSsl": "true",
        "certificatePath": "",
        "connectTimeoutSeconds": "2",
        "tcpUserTimeoutMs": "1000",
        "keepalivesIdleSec": "75",
        "keepalivesIntervalSec": "75",
        "keepalivesCount": "9",
        "targetSessionAttrs": "read-write",
        "enableScramAuthentication": "false",
        "connectionMaxAgeMinutes": "120"
      },
      "readOnly": {
        "targetSessionAttrs": "prefer-standby"
      }
    },
    "json-meta-schema": "@ERP_SCHEMA_DIR@shared/json/draft-4-meta-schema.json",
    "json-schema": [
      "@ERP_SCHEMA_DIR@hl7.fhir.r4.core/4.0.1/json/fhir.json",
      "@ERP_SCHEMA_DIR@shared/json/CommunicationDispReqPayloadV1.json",
      "@ERP_SCHEMA_DIR@shared/json/CommunicationReplyPayloadV1.json",
      "@ERP_SCHEMA_DIR@shared/json/CommunicationDispReqPayloadV3.json",
      "@ERP_SCHEMA_DIR@shared/json/CommunicationReplyPayloadV3.json"
    ],
    "xml-schema": [
      "@ERP_SCHEMA_DIR@hl7.fhir.r4.core/4.0.1/xml/fhir.xsd",
      "@ERP_SCHEMA_DIR@tsl/BNA_tsl.xsd",
      "@ERP_SCHEMA_DIR@tsl/Gematik_tsl.xsd",
      "@ERP_SCHEMA_DIR@vsdm/Pruefungsnachweis.xsd"
    ],
    "fhir": {
      "validation": {
        "urnUuidCheckFrom": "2025-10-01",
        "fullUrlAndBundleReferenceCheckFrom": "2099-01-01",
        "rejectUnslicedExtensionsFrom": "2026-04-01",
        "levels": {
          "unreferenced-bundled-resource": "error",
          "unreferenced-contained-resource": "error",
          "mandatory-resolvable-reference-failure": "error",
          "missing-or-extra-meta-profile": "error"
        }
      },
      "reference-time-offset-days": "0",
      "schluesseltabellen": [
        {
          "id": "2025-Q2",
          "valid-until": "2026-06-30",
          "groups": [
            "KBV-Schluesseltabellen-Q2/25"
          ]
        },
        {
          "id": "2026-Q3",
          "valid-from": "2026-07-01",
          "groups": [
            "KBV-Schluesseltabellen-Q3/26"
          ]
        }
      ],
      "resource-views": [
        {
          "id": "DAV_2023_07_01",
          "valid-until": "2025-04-15",
          "groups": [
            "de.abda.erezeptabgabedatenpkv-1.2"
          ]
        },
        {
          "id": "DAV_2025_01_15",
          "valid-from": "2025-01-15",
          "valid-until": "2026-01-11",
          "groups": [
            "de.abda.erezeptabgabedatenpkv-1.3"
          ]
        },
        {
          "id": "EU_2025_10_01",
          "valid-from": "2025-10-01",
          "groups": [
            "de.gematik.erezept.eu-1.1"
          ]
        },
        {
          "id": "GEM_WF_1_5_FDV",
          "valid-from": "2025-10-01",
          "valid-until": "2027-01-14",
          "groups": [
            "de.gematik.erezept-workflow.r4-1.5-FdV"
          ]
        },
        {
          "id": "GEM_WF_1_5_NON_FDV",
          "valid-from": "2025-10-01",
          "valid-until": "2026-09-30",
          "groups": [
            "de.gematik.erezept-workflow.r4-1.5-non-FdV"
          ]
        },
        {
          "id": "GEM_ERPCHRG_1_1",
          "valid-from": "2025-10-01",
          "groups": [
            "de.gematik.erezept-patientenrechnung.r4-1.1"
          ]
        },
        {
          "id": "GEM_WF_1_6_FDV",
          "valid-from": "2026-07-01",
          "groups": [
            "de.gematik.erezept-workflow.r4-1.6-FdV"
          ]
        },
        {
          "id": "GEM_WF_1_6_NON_FDV",
          "valid-from": "2026-07-01",
          "groups": [
            "de.gematik.erezept-workflow.r4-1.6-non-FdV"
          ]
        },
        {
          "id": "KBV_1_3",
          "valid-from": "2025-10-01",
          "valid-until": "2027-01-14",
          "groups": [
            "kbv.ita.erp-1.3"
          ]
        },
        {
          "id": "KBV_1_4",
          "valid-from": "2026-07-01",
          "groups": [
            "kbv.ita.erp-1.4"
          ]
        },
        {
          "id": "EVDGA_1_2",
          "valid-from": "2025-10-01",
          "groups": [
            "kbv.itv.evdga-1.2"
          ]
        },
        {
          "id": "DAV_1_4",
          "valid-from": "2025-10-01",
          "groups": [
            "de.abda.erezeptabgabedatenpkv-1.4"
          ]
        }
      ]
    },
    "redis": {
      "database": "0",
      "user": "",
      "password": "",
      "host": "localhost",
      "port": "6379",
      "certificatePath": "",
      "connectionPoolSize": "10",
      "connectionTimeout": "200",
      "sentinelSocketTimeout": "200",
      "dosSocketTimeoutMs": "100"
    },
    "hsm": {
      "device": "",
      "setup-username": "ERP_SETUP",
      "setup-password": "password",
      "work-username": "ERP_WORK",
      "work-password": "password",
      "max-session-count": "5",
      "tee-token": {
        "update-seconds": "1200",
        "retry-seconds": "30"
      },
      "cache-refresh-seconds": "300",
      "idle-timeout-seconds": "900",
      "connect-timeout-seconds": "5",
      "read-timeout-seconds": "1",
      "reconnect-interval-seconds": "15"
    },
    "registration": {
      "heartbeatIntervalSec": "30"
    },
    "compression": {
      "zstd": {
        "dictionary-dir": "@ERP_ZSTD_DICTIONARY_DIR@"
      }
    },
    "enrolment": {
      "server": {
        "port": "9191",
        "activateForPort": "9090"
      },
      "api": {
        "credentials": ""
      }
    },
    "c.fd.sig-erp-validation": "3600",
    "idp": {
      "registeredFdUri": "https://gematik.erppre.de/",
      "updateEndpoint": "https://idp.lu.erezepttest.net/.well-known/openid-configuration",
      "updateIntervalMinutes": "60",
      "noValidCertificateUpdateIntervalSeconds": "20",
      "certificateMaxAgeHours": "24",
      "sslRootCaPath": ""
    },
    "httpClientConnectTimeoutSeconds": "3",
    "httpClientResolveTimeoutMilliseconds": "2000",
    "feature": {
      "eu": "false",
      "t-rezept": "false"
    },
    "report": {
      "leips": {
        "enable": "false",
        "refreshIntervalSeconds": "15552000",
        "checkIntervalSeconds": "86400",
        "failedCheckIntervalSeconds": "300"
      }
    },
    "admin": {
      "server": {
        "interface": "0.0.0.0",
        "port": "9999"
      },
      "defaultShutdownDelaySeconds": "5",
      "credentials": "",
      "runtime_config_credentials": ""
    },
    "entropy_fetch_interval_seconds": "60",
    "timingCategories": [
      "fhirvalidation",
      "ocsprequest"
    ],
    "vsdmValiditySeconds": "1800",
    "popp": {
      "entityStatementUrl": "",
      "updateIntervalSeconds": "3600",
      "updateMaxAgeSeconds": "86400",
      "connectionTimeoutSeconds": "15",
      "responseTimeoutSeconds": "60",
      "tokenIatMaxAgeSeconds": "1800"
    }
  },
  "https-proxies": [],
  "http-proxies": []
}
