{
  "erp-medication-exporter": {
    "enable-epa": "true",
    "enable-t-rezept": "true",
    "is-production": "true",
    "server": {
      "thread-count": "8",
      "io-thread-count": "1"
    },
    "postgres": {
      "host": "localhost",
      "port": "5433",
      "user": "postgres",
      "password": "Postgres Admin Password",
      "database": "erp_medication_exporter",
      "useSsl": "true",
      "certificatePath": "",
      "connectTimeoutSeconds": "2",
      "tcpUserTimeoutMs": "1000",
      "keepalivesIdleSec": "75",
      "keepalivesIntervalSec": "75",
      "keepalivesCount": "9",
      "targetSessionAttrs": "read-write",
      "enableScramAuthentication": "false",
      "connectionMaxAgeMinutes": "120"
    },
    "ocsp": {
      "gracePeriodEpa": "3600"
    },
    "trusted-cas": "",
    "fhir-vzd-client": {
      "secret": "",
      "id": "",
      "tokenUrl": "auth-ref.vzd.ti-dienste.de",
      "tokenPort": "9443",
      "apiUrl": "fhir-directory-ref.vzd.ti-dienste.de",
      "apiPort": "443"
    },
    "bfarm-client": {
      "secret": "",
      "id": "",
      "url": "webapps-public.bfarm.de",
      "port": "443",
      "numRetries": "20",
      "maxExponentialBackoff": "8"
    },
    "vau-https-client": {
      "connectTimeoutMilliseconds": "1500",
      "sslHandshakeTimeoutMilliseconds": "3000",
      "messageSendTimeoutMilliseconds": "3000",
      "messageReceiveMilliseconds": "3000",
      "retryTimeoutMilliseconds": "3000",
      "retriesPerAddress": "3",
      "resolveTimeoutMilliseconds": "2000",
      "sticky": "true"
    },
    "epa-account-lookup": {
      "connectTimeoutSeconds": "2",
      "resolveTimeoutMilliseconds": "2000",
      "dnsRefreshInterval": "18:00:00",
      "endpoint": "/information/api/v1/ehr/consentdecisions",
      "erpSubmissionFunctionId": "erp-submission",
      "epaAsFqdn": [],
      "poolSizePerFqdn": "5",
      "throttleSeconds": "0"
    },
    "epa-conflict": {
      "epaConflictWaitMinutes": "1440"
    },
    "retries": {
      "maximumRetriesBeforeDeadletter": "8",
      "rescheduleDelaySeconds": "60"
    },
    "serno2tid": {
      "path": "/var/config/erp/config/SerNo2TID.csv",
      "hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    },
    "admin": {
      "server": {
        "interface": "0.0.0.0",
        "port": "9999"
      },
      "defaultShutdownDelaySeconds": "5",
      "credentials": "",
      "runtime_config_credentials": ""
    },
    "fhir": {
      "validation": {
        "levels": {
          "unreferenced-bundled-resource": "error",
          "unreferenced-contained-resource": "error",
          "mandatory-resolvable-reference-failure": "error",
          "missing-or-extra-meta-profile": "debug"
        }
      },
      "reference-time-offset-days": "0",
      "schluesseltabellen": [
        {
          "id": "2025-Q2",
          "valid-until": "2026-06-30",
          "groups": [
